{
  "version": 2,
  "outputDirectory": ".",
  "framework": null,
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml" },
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "backend/:path*" }
  ],
  "functions": {
    "backend/server.js": {
      "memory": 1024,
      "maxDuration": 60
    }
  }
}